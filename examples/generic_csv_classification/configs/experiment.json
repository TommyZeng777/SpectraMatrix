{
  "name": "generic_csv_classification",
  "dataset": {
    "path": "../data/spectra.csv",
    "sample_id_column": "sample_id",
    "target_column": "target"
  },
  "task": {
    "kind": "classification",
    "target_column": "target"
  },
  "split": {
    "method": "holdout",
    "test_size": 0.25,
    "stratify": true,
    "seed": 42
  },
  "preprocess": {
    "steps": ["snv"]
  },
  "model": {
    "name": "nearest_centroid"
  },
  "output_dir": "../../../outputs"
}

